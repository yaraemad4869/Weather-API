{
  "ConnectionStrings": {
    "Redis": "redis-prod.yourdomain.com:6379,password=YourStrongPassword,abortConnect=false,ssl=true,connectTimeout=10000"
  },
  "Redis": {
    "Configuration": {
      "ConnectionString": "redis-prod.yourdomain.com:6379",
      "Password": "YourStrongPassword",
      "DefaultDatabase": 0,
      "AbortOnConnectFail": false,
      "ConnectTimeout": 10000,
      "SyncTimeout": 10000,
      "ResponseTimeout": 10000,
      "KeepAlive": 180,
      "ConnectRetry": 5,
      "AllowAdmin": false,
      "Ssl": true,
      "SslHost": "redis-prod.yourdomain.com",
      "ClientName": "WeatherProject-Prod"
    },
    "CacheOptions": {
      "AbsoluteExpirationMinutes": 120,
      "SlidingExpirationMinutes": 60,
      "DefaultTTL": 7200
    }
  }
}